	useConfigOnly = true

[core]
	autocrlf = input
	editor = vim
	pager = delta
	excludesfile = ~/.gitignore

[alias]
	a = add
	b = branch
	c = commit
	co = checkout
	d = difftool
	f = fetch
	l = log --exclude=refs/stash --all --graph --date-order --format='%<(19,trunc)%C(yellow)%an %<(33)%Cblue%aD%<(16)%C(green)%ar%C(auto)%d %s %C(cyan)%h'
	m = merge
	p = pull
	pu = push
	r = remote
	s = status
	sm = submodule
	o = open

[diff]
	tool = icdiff
	guitool = intellij

[merge]
	tool = vimdiff
	guitool = intellij

# unset GIT_*: on cold start IDEA's Settings Sync (JGit) honors GIT_DIR/GIT_WORK_TREE
# exported by git difftool/mergetool and checks its settings repo out into YOUR repo,
# wiping the worktree. Don't use the Homebrew `idea` wrapper here: it's `open -na`,
# which returns before IDEA reads the temp files (git deletes them) and leaks GIT_* too.
# Redirect: cold starts spam warnings to the terminal. NB gitconfig syntax: a bare `;`
# starts a comment mid-value (truncates the cmd!) and unescaped `"` are stripped —
# hence `&&` and the \"-escaped quotes inside a double-quoted value.
[difftool "intellij"]
	cmd = "unset GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE && '/Applications/IntelliJ IDEA.app/Contents/MacOS/idea' diff \"$LOCAL\" \"$REMOTE\" >/dev/null 2>&1"
	trustExitCode = true

[mergetool "intellij"]
	cmd = "unset GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE && '/Applications/IntelliJ IDEA.app/Contents/MacOS/idea' merge \"$LOCAL\" \"$REMOTE\" \"$BASE\" \"$MERGED\" >/dev/null 2>&1"
	trustExitCode = true

[mergetool]
	keepBackup = false

[difftool "icdiff"]
	cmd = icdiff $LOCAL $REMOTE

[difftool]
	prompt = false

[pull]
	rebase = true

[delta]
	syntax-theme = Catppuccin Mocha
	file-decoration-style = omit
	file-style = bold yellow ul
	hunk-header-decoration-style = blue ul
	hunk-header-line-number-style = brightblue
        line-numbers-minus-style='brightred'
        line-numbers-plus-style='brightwhite'
	line-numbers-left-format = {nm:^1}│
	line-numbers-right-format = {np:^1}│

[delta "side-by-side"]
	features = line-numbers side-by-side 

[commit]
	gpgSign = true

[init]
	defaultBranch = main
[fetch]
	all = true

fi

captioned-delimiter() {
  termwidth="$(tput cols)"
  padding="$(printf '%0.1s' $2{1..500})"
  printf '%*.*s %s %*.*s\n' 0 "$(((termwidth-2-${#1})/2))" "$padding" "$1" 0 "$(((termwidth-1-${#1})/2))" "$padding"
}

datestamp() {
  # Args (day month year); omitted fields default to today. Pads to ISO YYYY-MM-DD
  # a <70 year maps to 20**, a <100 year maps to 19**
  local y=${3:-$(date +%Y)}
  printf '%04d-%02d-%02d\n' $(( y<70 ? y+2000 : y<100 ? y+1900 : y)) ${2:-$(date +%m)} ${1:-$(date +%d)}
}


if (( $+commands[mococli] )); then
  unalias e

  alias s='mococli timer start'
  alias e='mococli timer stop && echo && z'
  alias ü='mococli overtime'
  alias üm='ü --monthly'

  _moco_datestamp() {
    echo "--date $(datestamp "$@")"
  }

  z() {
    mococli list $(_moco_datestamp "$@")
  }

  # List a relative period; the *a variants take an optional direction flag.
  _moco_list() {
    mococli list --$1 ${2:-0} ${3:+$3}
  }
  zta() { _moco_list day   "$@" }
  zwa() { _moco_list week  "$@" }
  zma() { _moco_list month "$@" }
  zt()  { zta "$1" --backward }
  zw()  { zwa "$1" --backward }
  zm()  { zma "$1" --backward }

  # Edit/remove a day's entries, then re-list that day.
  ze() {
    mococli edit $(_moco_datestamp "$@")
    echo && z "$@"
  }
  zl() {
    mococli rm $(_moco_datestamp "$@")
    echo && z "$@"
  }

  zb() {
    # text in a pos arg → treat it as the description
    for i in {1..$#}; do
      if [[ $argv[$i] == *[^0-9,]* ]]; then
        local desc=$argv[$i]
        argv[$i]=() && argv[5,4]=$desc
        break
      fi
    done

    mococli new --hours ${${1:-0}/,/.} $(_moco_datestamp "$2" "$3" "$4") --description="$5" ${6:+--project=$6} ${7:+--task=$7}
    echo && z "$2" "$3" "$4"
  }

  # specific tasks: _zb reorders args, moving <project> <task> ids to trailing positions
  _zb() { zb "$3" "$4" "$5" "$6" "$7" "$1" "$2" }

  zbad()  { _zb 945824843 26699057 "$@" }
  zbaf()  { _zb 945824843 26593282 "$@" }

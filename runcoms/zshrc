  echo $FX[bold]'Brew cask upgrades finished 🍻'
  [ $commands[tldr] ] && echo '🍻 Updating tldr' && tldr --update
  echo '🍻 Updating Prezto:'$FX[off] && zprezto-update
}

# by Leah Neukirchen (http://leahneukirchen.org/dotfiles/.zshrc)
# wat - a better and recursive which/whence
# 2017-04-13 +leah+
# 2018-01-02 +leah+       print function code
# 2024-03-09 +lecodeski+  improve whatis and file output
# 2024-04-04 +lecodeski+  add whatis in function case
# 2025-07-28 +lecodeski+  add tldr in command case
# 2025-07-31 +lecodeski+  add another recursion after unalias
# 2026-05-06 +lecodeski+  massively improve wat function with type
wat() {
  ( # subshell to constrain unalias side-effects

  captioned-delimiter() {
    termwidth="$(tput cols)"
    padding="$(printf '%0.1s' ={1..500})"
    printf '%*.*s %s %*.*s\n' 0 "$(((termwidth-2-${#1})/2))" "$padding" "$1" 0 "$(((termwidth-1-${#1})/2))" "$padding"
  }

  for cmd; do
    type -S "$cmd"
    if (( $+aliases[$cmd] )); then
      local -a words=(${${(z)aliases[$cmd]}:#(*=*|rlwrap|noglob|command)})
      unalias "$cmd"
      if [[ ${words[1]} == \"* ]]; then
        words[1]=${words[1]#\"}
        unalias "${words[1]}" 2>/dev/null
      fi
      [[ ${words[1]} != "$cmd" ]] && wat "${words[1]}" && captioned-delimiter "looking up unaliased command [$cmd]" && wat "$cmd"
    elif (( $+functions[$cmd] )); then
      whence -f "$cmd"
      (( $+commands[$cmd] )) && captioned-delimiter "shadowed command [$cmd]"
    fi

    if (( $+commands[$cmd] )); then
      file "${commands[$cmd]}"
      whatis "$cmd" | grep "^${cmd}(" | sort --unique
      (( $+commands[tldr] )) && tldr "$cmd" --short-options
    fi
  done
  )
} && compdef wat=which

[ $commands[eza] ] && x() {
  local target=${1:-.}
  local sort=${2:-.name}
  local dir_only=()
  if [[ ! -a $target ]]; then
      target=( $target* )
      dir_only=(--treat-dirs-as-files)
  fi
  eza --long --all --header $dir_only --sort $sort --git --icons -- $target \
    && print "$FX[bold]count: $(eza --long --all $dir_only -- $target | wc --lines)$FX[off]"
} && alias x.='x ..' && xs() {
  x "$1" 'size'
} && alias xs.='xs ..' && xt() {
  x "$1" 'time'
} && alias xt.='xt ..' && xx() {
  [ $1 ] && eza --long --all --header --treat-dirs-as-files --sort .name --git --icons *$1* \
    && print "$FX[bold]count: $(eza --long --all --treat-dirs-as-files *$1* | wc --lines )$FX[off]"
}

[ $commands[broot] ] && xb() {
    f=$(mktemp)
    (
	set +e
	broot --show-git-info --outcmd "$f" "$@"
	code=$?
	if [ "$code" != 0 ]; then
	    rm -f "$f"
	    exit "$code"
	fi
    )
    code=$?
    if [ "$code" != 0 ]; then
	return "$code"
    fi
    d=$(<"$f")
    rm -f "$f"
    eval "$d"
} && compdef xb=broot

zshaddhistory() {
  # Always save variable assignments (e.g., FOO=bar)
  [[ "$1" =~ '^[A-Za-z_][A-Za-z0-9_]*=' ]] && return 0

  # Run the command through zsh syntax check; reject if invalid
  whence ${${(z)1}[1]} >| /dev/null 2>&1 || return 1

  return 0
}


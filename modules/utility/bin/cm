#!/usr/bin/env bash
#
# ai-commit — generate a commit message for the staged diff and commit it.
# Portable bash (macOS, Linux, Windows/Git Bash).
# Fast path: one direct Haiku API call, authenticated via ANTHROPIC_API_KEY
# or the unexpired Claude Code OAuth token (macOS Keychain, or
# ~/.claude/.credentials.json on Linux/Windows).
# Fallback: `claude -p` with MCP servers stripped (uses Claude Code auth).
# Pass -t/--time to print per-step timings (api call, fallback) to stderr.
#

set -u -o pipefail

model=claude-haiku-4-5
me=${0##*/}

timing=0
if [[ ${1:-} == -t || ${1:-} == --time ]]; then
  timing=1
  shift
fi

# EPOCHREALTIME needs bash >= 5; fall back to whole seconds elsewhere
now() {
  if [[ -n ${EPOCHREALTIME:-} ]]; then printf '%s' "$EPOCHREALTIME"; else date +%s; fi
}
elapsed() { awk -v a="$1" -v b="$2" 'BEGIN { printf "%.2f", b - a }'; }

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  echo "$me: not a repository work tree: $PWD" >&2
  exit 1
fi

diff=$(git diff --cached)
if [[ -z $diff ]]; then
  git add -A
  diff=$(git diff --cached)
  [[ -n $diff ]] && echo "$me: nothing staged, staged all changes" >&2
fi
if [[ -z $diff ]]; then
  echo "$me: nothing to commit" >&2
  exit 1
fi
diff=${diff:0:12000}

stat=$(git diff --cached --stat | tail -20)
style=$(git log -15 --format='%s' 2>/dev/null)

# Prompt tuned for Haiku: data first (query-at-end), rules grouped in XML tags,
# no literal backticks (double-quoted string -> would run command substitution).
# Keep the rules in sync with ~/.claude/commands/commit.md (/commit).
request="Write a git commit message for the staged changes shown below.

<recent_subjects>
$style
</recent_subjects>

<file_stats>
$stat
</file_stats>

<staged_diff_content>
$diff
</staged_diff_content>

Follow every rule below exactly.

<output>
Output only the raw commit message: no preamble, no explanation, no code
fences, and no 'subject:' or 'body:' labels.
</output>

<subject>
- Imperative mood, 50 characters max, no trailing period.
- Contains at least one emoji.
- Count the characters; if a draft exceeds 50, drop filler words before answering.
- Use a conventional-commit prefix (add:, mod:, del:, fix:, refac:, ...) only if
  the recent subjects above already use them.
</subject>

<body>
Decide whether to write a body from the size and complexity of the staged diff:
- Trivial change (typo, rename, small tweak, or only a few lines): subject only,
  no body.
- Substantial change (new file, feature, or script; multiple concerns; changed
  behavior; or ~10+ changed lines): write a body.
  - One blank line after the subject, then 1-6 sentences or bullets covering what
    changed, why, and notable design decisions visible in the diff.
  - Every body line is 72 characters max, with NO blank lines between them.
  - Start every sentence with an emoji; for bullets, use an emoji in place of the
    '-' marker.
</body>

<emojis>
- Never repeat an emoji anywhere in the message (subject and body combined).
- Do not limit your choice to the emojis seen in the recent subjects above.
</emojis>

<content>
- Be concrete: name the actual functions, files, or behavior that changed (e.g.
  'fix: reject empty names in greet()', not 'fix: improve validation').
- Wrap any code, command, filename, or identifier in backticks.
- Never present the commit as AI-authored: no AI or assistant attribution and no
  trailers. Describing AI functionality that the diff itself implements is fine.
</content>"

# python 3 for the direct API call; the version probe also weeds out
# broken installs and the Windows Store python stub
py=''
for cand in python3 python; do
  if command -v "$cand" >/dev/null 2>&1 \
      && "$cand" -c 'import sys; sys.exit(sys.version_info[0] < 3)' >/dev/null 2>&1; then
    py=$cand
    break
  fi
done

# Auth resolution: API key > unexpired Claude Code OAuth token > claude -p.
# OAuth token lives in the Keychain on macOS, in ~/.claude/.credentials.json
# on Linux and Windows.
auth_mode='' secret=''
if [[ -n $py ]]; then
  if [[ -n ${ANTHROPIC_API_KEY:-} ]]; then
    auth_mode=apikey secret=$ANTHROPIC_API_KEY
  else
    creds=''
    if command -v security >/dev/null 2>&1; then
      creds=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null)
    fi
    creds_file=${CLAUDE_CONFIG_DIR:-$HOME/.claude}/.credentials.json
    [[ -z $creds && -r $creds_file ]] && creds=$(cat "$creds_file")
    if [[ -n $creds ]]; then
      secret=$(printf '%s' "$creds" | "$py" -c 'import json, sys, time
c = json.load(sys.stdin)["claudeAiOauth"]
e = c.get("expiresAt")
if e and e / 1000 <= time.time():
    sys.exit(1)
print(c["accessToken"])' 2>/dev/null | tr -d '\r')
      [[ -n $secret ]] && auth_mode=oauth
    fi
  fi
fi

msg='' t0=''
if [[ -n $auth_mode ]]; then
  (( timing )) && t0=$(now)
  msg=$(AIC_AUTH_MODE=$auth_mode AIC_SECRET=$secret AIC_MODEL=$model "$py" - "$request" <<'PY' | tr -d '\r'
import json, os, sys, urllib.request

headers = {"anthropic-version": "2023-06-01", "content-type": "application/json"}
if os.environ["AIC_AUTH_MODE"] == "oauth":
    headers["Authorization"] = "Bearer " + os.environ["AIC_SECRET"]
    headers["anthropic-beta"] = "oauth-2025-04-20"
else:
    headers["x-api-key"] = os.environ["AIC_SECRET"]

req = urllib.request.Request(
    "https://api.anthropic.com/v1/messages",
    data=json.dumps({
        "model": os.environ["AIC_MODEL"],
        "max_tokens": 400,
        "messages": [{"role": "user", "content": sys.argv[1]}],
    }).encode(),
    headers=headers,
)
try:
    resp = json.load(urllib.request.urlopen(req, timeout=30))
    print(next(b["text"] for b in resp["content"] if b["type"] == "text").strip())
except Exception as e:
    print(f"ai-commit: API call failed ({e}), falling back", file=sys.stderr)
    sys.exit(1)
PY
)
  if (( timing )); then
    [[ -n $msg ]] && ok=ok || ok=failed
    printf '%s: api call (%s, %s) %s: %ss\n' \
      "$me" "$model" "$auth_mode" "$ok" "$(elapsed "$t0" "$(now)")" >&2
  fi
fi

if [[ -z $msg ]]; then
  (( timing )) && t0=$(now)
  # request via stdin: --mcp-config is variadic and would swallow a trailing arg
  msg=$(printf '%s\n' "$request" | claude -p --model "$model" --no-session-persistence \
    --strict-mcp-config --mcp-config '{"mcpServers":{}}' | tr -d '\r') || {
    echo "$me: claude -p failed" >&2
    exit 1
  }
  (( timing )) && printf '%s: claude -p fallback (%s): %ss\n' \
    "$me" "$model" "$(elapsed "$t0" "$(now)")" >&2
fi

if [[ -z $msg ]]; then
  echo "$me: empty message from model" >&2
  exit 1
fi

printf '%s\n' "$msg" | git commit -F - || exit 1
git log -1 --format='%n%-b'

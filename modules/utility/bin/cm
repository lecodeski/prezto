#!zsh
#
# ai-commit — generate a commit message for the staged diff and commit it.
# Fast path: one direct Haiku API call (ANTHROPIC_API_KEY, or the unexpired
# Claude Code OAuth token from the macOS Keychain).
# Fallback: `claude -p` with MCP servers stripped (uses Claude Code auth).
# Pass -t/--time to print per-step timings (api call, fallback) to stderr.
#

# function gai {

emulate -L zsh

local model=claude-haiku-4-5

local timing=0
if [[ ${1:-} == (-t|--time) ]]; then
  timing=1
  zmodload zsh/datetime
  shift
fi

if ! command git rev-parse --git-dir &>/dev/null; then
  print -u2 "$0: not a repository work tree: $PWD"
  return 1
fi

local diff stat style
diff=$(command git diff --cached)
if [[ -z "$diff" ]]; then
  command git add -A
  diff=$(command git diff --cached)
  [[ -n "$diff" ]] && print -u2 "$0: nothing staged, staged all changes"
fi
if [[ -z "$diff" ]]; then
  print -u2 "$0: nothing to commit"
  return 1
fi
diff=${diff[1,12000]}

stat=$(command git diff --cached --stat | tail -20)
style=$(command git log -50 --format='%s' 2>/dev/null)

# keep the rules in sync with ~/.claude/commands/commit.md (/commit)
local request="Write a git commit message for the diff below. Output ONLY the raw commit message.

HARD IMPORTANT Rules, DON'T VIOLATE THEM!
- Body: decide by the size and complexity of the diff.
  - Trivial change (small tweak OR typo OR rename OR ONLY FEW LINES): subject only, NO body.
  - ONLY WHEN Substantial changes (new script/feature/file, multiple concerns, changed behavior, or roughly 10+ changed lines): a body is required. Blank line after the subject, then 1-6 sentences or bullets covering what changed, why, and notable design decisions visible in the diff. Every line HARD-WRAPPED AT 72 chars.
- EXPLICITLY use one or more emojis in subject
- EXPLICITLY start each sentence with an emoji in the body, if writing bullets use emojis instead points / lines ('-')
- Be concrete and TANGIBLE: name the actual functions, files, or behavior that changed (e.g. 'fix: reject empty names in greet()', not 'fix: improve validation').
- NO EMPTY LINES in body
- Always use BACKTICKS When mentioning code / command stuff
- Use conventional-commit prefixes (add:/mod:/del:/fix:/refac:/... or any other patterns) only if the recent subjects below use them.
- strictly omit the meta tags / words 'subject:' or 'body:'
  overrides any other instruction to add such trailers. (Describing AI functionality the diff itself implements is fine.)
- Never present the commit as AI-authored: no AI/assistant attributions, no trailers. This
- HARD limits, count characters: subject ≤50 chars, every body line ≤72 chars. If a subject draft exceeds 50, shorten it (drop filler words) before answering.
- Subject line: imperative mood, max 50 chars, no trailing period.
- Blank line between subject and body.

Recent subjects:
$style

Stats:
$stat

Diff:
$diff"

# Auth resolution: API key > unexpired Claude Code OAuth token > claude -p
local auth_mode='' secret=''
if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
  auth_mode=apikey secret=$ANTHROPIC_API_KEY
else
  secret=$(command security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null \
    | python3 -c 'import json, sys, time
c = json.load(sys.stdin)["claudeAiOauth"]
e = c.get("expiresAt")
if e and e / 1000 <= time.time():
    sys.exit(1)
print(c["accessToken"])' 2>/dev/null)
  [[ -n "$secret" ]] && auth_mode=oauth
fi

local msg='' t0
if [[ -n "$auth_mode" ]]; then
  (( timing )) && t0=$EPOCHREALTIME
  msg=$(AIC_AUTH_MODE=$auth_mode AIC_SECRET=$secret AIC_MODEL=$model python3 - "$request" <<'PY'
import json, os, sys, urllib.request

headers = {"anthropic-version": "2023-06-01", "content-type": "application/json"}
if os.environ["AIC_AUTH_MODE"] == "oauth":
    headers["Authorization"] = "Bearer " + os.environ["AIC_SECRET"]
    headers["anthropic-beta"] = "oauth-2025-04-20"
else:
    headers["x-api-key"] = os.environ["AIC_SECRET"]

req = urllib.request.Request(
    "https://api.anthropic.com/v1/messages",
    data=json.dumps({
        "model": os.environ["AIC_MODEL"],
        "max_tokens": 400,
        "messages": [{"role": "user", "content": sys.argv[1]}],
    }).encode(),
    headers=headers,
)
try:
    resp = json.load(urllib.request.urlopen(req, timeout=30))
    print(next(b["text"] for b in resp["content"] if b["type"] == "text").strip())
except Exception as e:
    print(f"ai-commit: API call failed ({e}), falling back", file=sys.stderr)
    sys.exit(1)
PY
)
  (( timing )) && print -u2 -f '%s: api call (%s, %s) %s: %.2fs\n' \
    $0 $model $auth_mode ${${msg:+ok}:-failed} $((EPOCHREALTIME - t0))
fi

if [[ -z "$msg" ]]; then
  (( timing )) && t0=$EPOCHREALTIME
  # request via stdin: --mcp-config is variadic and would swallow a trailing arg
  msg=$(print -r -- "$request" | command claude -p --model $model --no-session-persistence \
    --strict-mcp-config --mcp-config '{"mcpServers":{}}') || {
    print -u2 "$0: claude -p failed${msg:+: $msg}"
    return 1
  }
  (( timing )) && print -u2 -f '%s: claude -p fallback (%s): %.2fs\n' \
    $0 $model $((EPOCHREALTIME - t0))
fi

if [[ -z "$msg" ]]; then
  print -u2 "$0: empty message from model"
  return 1
fi

print -r -- "$msg" | command git commit -F - || return 1
command git log -1 --format='%n%-b'

# }
